# ─── Ledgerlens — Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── AI Service (GitHub Copilot SDK) ─────────────────────────────────────
# Auth: the Copilot SDK uses your GitHub CLI login by default (gh auth login).
# Alternatively, set one of these tokens:
# GITHUB_TOKEN=ghp_...
# GH_TOKEN=ghp_...
# COPILOT_GITHUB_TOKEN=ghp_...

# Default Copilot model (override in Settings UI):
# LEDGERLENS_COPILOT_MODEL=gpt-4o

# ─── Microsoft Entra ID (for user sign-in & Graph/SharePoint connectors) ─
LEDGERLENS_CLIENT_ID=YOUR_APP_CLIENT_ID
LEDGERLENS_TENANT_ID=common
LEDGERLENS_APP_ID_URI=api://YOUR_APP_CLIENT_ID
LEDGERLENS_ENABLE_NAA=false
LEDGERLENS_REDIRECT_URI=https://localhost:3000/taskpane.html

# ─── SQL Proxy (optional) ────────────────────────────────────────────────
# The SQL connector talks to a lightweight proxy API, not directly to a DB.
# LEDGERLENS_SQL_PROXY_URL=https://your-sql-proxy.azurewebsites.net

# ─── MCP Servers (optional) ─────────────────────────────────────────────
# MCP servers are configured at runtime via the Data Sources UI panel.
# Supports both Streamable HTTP and legacy SSE transports.
# Example: http://localhost:3001/mcp

# ─── Dev Server ─────────────────────────────────────────────────────────
PORT=3000
