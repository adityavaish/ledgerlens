{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev Server",
      "type": "shell",
      "command": "npm run dev-server",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "webpack compiled"
        }
      }
    },
    {
      "label": "Sideload Office Add-in",
      "type": "shell",
      "command": "npx office-addin-dev-settings sideload manifest.xml",
      "dependsOn": "Dev Server"
    }
  ]
}
