{
  "name": "ledgerlens-excel-addin",
  "version": "1.0.0",
  "description": "Ledgerlens — AI assistant in Excel for finance and accounting teams. Pull, analyze, and reconcile corporate accounting data with natural language.",
  "private": true,
  "main": "server.js",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "start:mcp-bridge": "node scripts/local-mcp-bridge.js",
    "start": "node server.js",
    "start:debug": "office-addin-debugging start manifest.xml",
    "start:desktop": "office-addin-debugging start manifest.xml desktop",
    "start:web": "office-addin-debugging start manifest.xml web",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "lint": "eslint src/",
    "test": "jest --coverage",
    "sideload": "office-addin-dev-certs install && webpack serve --mode development",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/msal-browser": "^3.10.0",
    "@github/copilot-sdk": "^0.1.32",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.0",
    "jose": "^6.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.10.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.8.0",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-manifest": "^2.1.2",
    "style-loader": "^3.3.4",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "axios": "^1.16.0",
    "serialize-javascript": "^7.0.5",
    "brace-expansion": "^2.0.2",
    "picomatch": "^4.0.3",
    "ip-address": "^10.0.1",
    "protobufjs": "^8.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
