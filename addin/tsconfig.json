{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2020"],
    "types": ["office-js"],
    "outDir": "dist"
  },
  "include": ["src/**/*", "../shared/src/**/*"]
}
